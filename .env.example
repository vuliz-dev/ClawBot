# ═══════════════════════════════════════════════════════════════
# ClawBot Environment Variables
# For local dev: copy to .env, for Render: set in dashboard
# ═══════════════════════════════════════════════════════════════

# REQUIRED
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Provider: anthropic | openai | ollama | google
AI_PROVIDER=anthropic

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
GOOGLE_API_KEY=
IMAGE_API_KEY=

# Model Config
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8192
THINKING_BUDGET_TOKENS=4096

# System
SYSTEM_PROMPT=
DB_PATH=./data/clawbot.db
GATEWAY_PORT=3000
STREAM_THROTTLE_MS=800

# Context & History
MAX_HISTORY_TURNS=20
MAX_CONTEXT_TOKENS=80000

# Access Control
ALLOWED_USER_IDS=
# Pairing code: users can /pair <code> to join without whitelist
PAIRING_CODE=010923

# Bash & Security
BASH_TIMEOUT_MS=30000
BASH_APPROVAL_MODE=smart
ALLOW_HOST_BASH=false

# File I/O
WORKSPACE_DIR=./workspace

# WebSocket (optional)
WS_SECRET=
